# Anthropic API key (optional). If omitted, the pipeline falls back to a high-quality mock generator.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model to use. Default is claude-sonnet-4-5.
ANTHROPIC_MODEL=claude-sonnet-4-5

# HubSpot is fully mocked in this project. No key needed.
# If you later swap in the real HubSpot SDK, add:
# HUBSPOT_ACCESS_TOKEN=
